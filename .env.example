# Copy to .env locally OR paste these into Dokploy's Environment tab.
# Anything left blank is fine — Odysseus generates an admin password on
# first boot if ODYSSEUS_ADMIN_PASSWORD is empty (check container logs).

# --- Required for a public-facing deployment ---
AUTH_ENABLED=true
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=

# Long random string. Generate with: openssl rand -base64 48
SEARXNG_SECRET=

# --- Build pinning ---
# Set to a commit SHA in production. "main" is fine for testing.
ODYSSEUS_REF=main
# Bump this (any new value) to force a re-clone on rebuild.
CACHEBUST=1

# --- Optional provider keys ---
OPENAI_API_KEY=
OLLAMA_BASE_URL=
HF_TOKEN=

# --- Networking ---
APP_BIND=0.0.0.0
APP_PORT=7000

# --- Host user mapping (so bind-mounted files stay editable) ---
# Find yours with: id -u / id -g
PUID=1000
PGID=1000

# --- Database — default SQLite at /app/data/app.db is fine ---
# DATABASE_URL=postgresql://user:pass@host:5432/odysseus
